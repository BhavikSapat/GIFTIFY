{
  "tabs": {
    "basicInfo": {
      "type": "section",
      "label": "Basic Information",
      "fields": [
        {
          "name": "companyName",
          "type": "text",
          "label": "Company Name",
          "placeholder": "GIFTIFY"
        },
        {
          "name": "logo",
          "type": "url",
          "label": "Company Logo URL",
          "placeholder": "https://bitbusters.netlify.app/logo.png"
        },
        {
          "name": "tagline",
          "type": "text",
          "label": "Tagline",
          "placeholder": "Luxury Corporate Gifting"
        }
      ]
    },
    "heroSection": {
      "type": "section",
      "label": "Hero Section",
      "fields": [
        {
          "name": "title",
          "type": "text",
          "label": "Hero Title",
          "placeholder": "Curate the Perfect"
