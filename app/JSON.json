          "placeholder": "We believe that the unboxing experience is just as important as the gift itself. Every detail, from the textured ribbon to the weight of the cardstock, is meticulously chosen to exude elegance."
        },
        {
          "name": "image",
          "type": "url",
          "label": "About Image URL",
          "placeholder": "https://m.media-amazon.com/images/I/910JoLxRjoL._AC_UF894,1000_QL80_.jpg"
        }
      ]
    },
    "giftsSection": {
      "type": "dynamic-section",
      "label": "Gifts Section",
